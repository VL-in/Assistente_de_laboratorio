# URL base da API OpenAI do LM Studio (aba "Server" / servidor local).
# Deve terminar em /v1 — é o que o SDK OpenAI espera em base_url.
LLM_BASE_URL=http://127.0.0.1:1234/v1

# Nome exato do modelo carregado no LM Studio (copie da interface ao iniciar o servidor).
LLM_MODEL=replace-with-your-model-id

# LM Studio normalmente não exige chave real; o SDK OpenAI exige um valor — use qualquer string.
# Também aceito: OPENAI_API_KEY (mesmo nome que no docker-compose da raiz do repositório).
LLM_API_KEY=lm-studio
