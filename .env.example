# Copie para .env e preencha os valores. O .env está no .gitignore — nunca commite segredos.
# No Render: configure estas variáveis em Dashboard → Environment.

# =============================================================================
# OBRIGATÓRIO
# =============================================================================

# Chave da API do OpenRouter (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-substitua-pela-chave-real

# Modelo LLM. "openrouter/auto" deixa a plataforma escolher o melhor disponível.
# Outros: meta-llama/llama-3.3-70b-instruct:free | qwen/qwen3.5-7b-instruct:free
LLM_MODEL=openrouter/auto

# Pasta com os documentos do laboratório (um subdiretório por projeto).
# Docker local: caminho absoluto no host, ex.: D:/Vanessa/AI_project/Projetos
# Render: caminho do disco persistente montado, ex.: /data/projetos
PROJETOS_HOST_DIR=/data/projetos

# =============================================================================
# OPCIONAL — Observabilidade (Langfuse)
# =============================================================================
# Traces de cada conversa (prompt, modelo, tokens, latência).
# Crie as chaves em https://cloud.langfuse.com → Settings → API Keys.
# Deixe em branco para desativar.

# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# =============================================================================
# OPCIONAL — Ajustes de comportamento
# =============================================================================

# Porta do Streamlit (padrão 8502). No Render, use $PORT (gerenciado pela plataforma).
# STREAMLIT_PORT=8502

# Modelo usado nas predições via chat (caminho para o .pkl treinado offline).
# Deixe em branco se não tiver modelo treinado — funcionalidade ML fica inativa.
# ASSISTENTE_ML_CHAT_MODEL=/data/ml/modelo.pkl

# Timeout das chamadas ao OpenRouter em segundos (padrão 120).
# LLM_TIMEOUT_S=120

# =============================================================================
# OPCIONAL — Segurança (tudo ativo por padrão, desative com 0 se necessário)
# =============================================================================

# SECURITY_INPUT_GUARD_ENABLED=1    # Bloqueia prompt injection na entrada
# SECURITY_BAN_CODE_ENABLED=1       # Bloqueia blocos de código na entrada
# SECURITY_PII_REDACTION_ENABLED=1  # Redige PII antes de enviar ao OpenRouter
# SECURITY_OUTPUT_GUARD_ENABLED=1   # Neutraliza links de exfiltração na saída
# SECURITY_TOXICITY_ENABLED=1       # Detecta linguagem ofensiva

# =============================================================================
# DOCKER LOCAL — apenas se rodar com docker compose
# =============================================================================

# STREAMLIT_PORT=8502
# EMBEDDING_SERVICE_URL=http://embeddings:80   # Serviço TEI no Compose
