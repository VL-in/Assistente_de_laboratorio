# Copie para `.env` na raiz do repositório e ajuste.
# O Docker Compose lê esse arquivo automaticamente.

# Onde estão as pastas de cada projeto no seu PC (host)
PROJETOS_HOST_DIR=D:/Vanessa/AI_project/Projetos

# Porta publicada no host
STREAMLIT_PORT=8502

# LM Studio no host (API compatível com OpenAI)
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_MODEL=nome-exato-do-modelo-no-lm-studio
OPENAI_API_KEY=lm-studio
